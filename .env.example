AEGIS_DB_PATH=data/aegis.db
AEGIS_ARTIFACT_DIR=artifacts
AEGIS_REPORT_DIR=reports
AEGIS_MARKET_DATA_MODE=mock
AEGIS_EXECUTION_MODE=paper
AEGIS_KRAKEN_BACKEND=rest
AEGIS_KRAKEN_EXECUTION_MODE=paper
AEGIS_KRAKEN_BASE_URL=https://api.kraken.com
AEGIS_KRAKEN_TIMEOUT_SECONDS=5
AEGIS_KRAKEN_OHLC_INTERVAL_MINUTES=60
AEGIS_KRAKEN_HISTORY_LENGTH=60
AEGIS_KRAKEN_ALLOW_FALLBACK_TO_MOCK=true
AEGIS_KRAKEN_USER_AGENT=Aegis-local-demo
AEGIS_KRAKEN_CLI_COMMAND=kraken
AEGIS_KRAKEN_CLI_TIMEOUT_SECONDS=10
AEGIS_KRAKEN_CLI_ALLOW_FALLBACK_TO_REST=true
AEGIS_KRAKEN_EXECUTION_ALLOW_FALLBACK_TO_INTERNAL_PAPER=true
AEGIS_ENABLE_KRAKEN_LIVE=false
AEGIS_ENABLE_KRAKEN_LIVE_SUBMIT=false
AEGIS_KRAKEN_LIVE_REQUIRE_VALIDATE=true
AEGIS_KRAKEN_LIVE_MAX_NOTIONAL_PER_ORDER=50
AEGIS_KRAKEN_LIVE_MAX_DAILY_NOTIONAL=100
AEGIS_KRAKEN_LIVE_MAX_ORDERS_PER_CYCLE=1
AEGIS_KRAKEN_LIVE_CONFIRMATION_TEXT=ENABLE_LIVE_ORDERS
AEGIS_KRAKEN_LIVE_ALLOWED_SYMBOLS=BTC/USD,ETH/USD,SOL/USD
AEGIS_STARTING_CASH=100000
AEGIS_MAX_RISK_PER_TRADE=0.10
AEGIS_MAX_DAILY_DRAWDOWN=0.05
AEGIS_MAX_OPEN_POSITIONS=3
AEGIS_COOLDOWN_AFTER_LOSSES=2
AEGIS_KILL_SWITCH=false
